{
  "formatter": {
    "external": {
      "command": "pnpm",
      "arguments": ["biome", "format", "--write", "--stdin-file-path", "{buffer_path}"]
    }
  },
  "format_on_save": "on",
  "languages": {
    "TypeScript": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "TSX": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "JavaScript": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "JSON": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    }
  }
}
